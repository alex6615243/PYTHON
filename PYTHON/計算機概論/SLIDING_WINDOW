import matplotlib.pyplot as plt
import matplotlib.animation as animation
import matplotlib.patches as patches

# 設定參數
TOTAL_PACKETS = 20  # 總封包數
WINDOW_SIZE = 5     # 窗口大小 (Window Size)

# 模擬狀態
# 0: 未發送 (Not Usable / Future)
# 1: 窗口內可發送 (Usable Window)
# 2: 已發送未確認 (Sent, Not ACKed)
# 3: 已確認 (ACKed)

fig, ax = plt.subplots(figsize=(10, 4))
ax.set_xlim(-1, TOTAL_PACKETS)
ax.set_ylim(0, 4)
ax.set_yticks([])
ax.set_title("TCP Sliding Window Mechanism", fontsize=14, fontweight='bold')

# 初始化圖形物件
packets = []
for i in range(TOTAL_PACKETS):
    # 每個封包是一個長條圖
    rect = patches.Rectangle((i, 1), 0.8, 1, edgecolor='black', facecolor='white')
    ax.add_patch(rect)
    # 封包序號
    ax.text(i + 0.4, 1.5, str(i), ha='center', va='center', fontsize=10)
    packets.append(rect)

# 窗口框 (紅色框框代表 Window)
window_frame = patches.Rectangle((0, 0.8), WINDOW_SIZE, 1.4, linewidth=3, edgecolor='red', facecolor='none')
ax.add_patch(window_frame)

# 狀態標籤
status_text = ax.text(0, 3, "", fontsize=12, color='blue')

# 定義顏色
COLOR_ACKED = '#2ecc71'  # 綠色
COLOR_SENT = '#f1c40f'   # 黃色
COLOR_USABLE = '#3498db' # 藍色
COLOR_FUTURE = '#ecf0f1' # 灰白色

def init():
    window_frame.set_xy((0, 0.8))
    status_text.set_text("Start: Window Size = 5")
    for p in packets:
        p.set_facecolor(COLOR_FUTURE)
    # 初始窗口內的設為藍色
    for i in range(WINDOW_SIZE):
        packets[i].set_facecolor(COLOR_USABLE)
    return packets + [window_frame, status_text]

def animate(frame):
    # 模擬簡單的滑動邏輯
    # 假設每 2 幀發送一次，每 3 幀收到一個 ACK 並滑動
    
    current_ack = frame // 3  # 模擬 ACK 進度 (窗口左邊界)
    window_end = current_ack + WINDOW_SIZE
    
    # 防止溢出
    if window_end > TOTAL_PACKETS:
        window_end = TOTAL_PACKETS
        
    # 移動紅色窗口框
    window_frame.set_xy((current_ack, 0.8))
    
    # 更新每個封包的顏色狀態
    for i in range(TOTAL_PACKETS):
        if i < current_ack:
            packets[i].set_facecolor(COLOR_ACKED) # 綠色：已確認
        elif i < window_end:
            # 在窗口內
            # 簡單模擬：窗口左邊的一半是已發送(黃)，右邊是可發送(藍)
            if i < current_ack + (frame % 3) + 1: 
                packets[i].set_facecolor(COLOR_SENT) # 黃色：已發送
            else:
                packets[i].set_facecolor(COLOR_USABLE) # 藍色：可發送
        else:
            packets[i].set_facecolor(COLOR_FUTURE) # 灰色：窗口外
            
    # 更新文字解說
    status_text.set_text(f"Step {frame}: Window at [{current_ack} - {window_end-1}]")
    
    if current_ack >= TOTAL_PACKETS - WINDOW_SIZE:
        status_text.set_text("Transmission Complete!")

    return packets + [window_frame, status_text]

ani = animation.FuncAnimation(fig, animate, frames=40, init_func=init, blit=True, interval=200)

# 如果在 Jupyter/Colab 中，請使用這行來顯示
try:
    from IPython.display import HTML
    display(HTML(ani.to_jshtml()))
except:
    plt.show()